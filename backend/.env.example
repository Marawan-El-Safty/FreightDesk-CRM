NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=freightdesk_crm
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Email (Gmail OAuth2 or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sales@freightdesk.demo
SMTP_PASS=your_app_password

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Company info
COMPANY_NAME=FreightDesk
COMPANY_LOGO=https://www.freightdesk.demo/SubmarkLogo.png
COMPANY_EMAIL=sales@freightdesk.demo
COMPANY_PHONE=+20 111 8 111 463
COMPANY_ADDRESS=6 Abdelfattah Yahia St - Raml Station, Alexandria, Egypt
